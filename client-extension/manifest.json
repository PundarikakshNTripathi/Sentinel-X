{
  "manifest_version": 3,
  "name": "Sentinel-X",
  "version": "1.0.0",
  "description": "Zero-latency multimodal endpoint security daemon.",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}